+/******************************************************************************
+ *                          page-level controls
+ ******************************************************************************/
+
+#define MGLRU_PAGE_POLICY_PROTECT	BIT(0)
+#define MGLRU_PAGE_POLICY_SKIP		BIT(1)
+#define MGLRU_PAGE_POLICY_ONLY		BIT(2)
+
+struct mglru_page_policy {
+	struct list_head list;
+	unsigned long pfn;
+	unsigned int flags;
+	int skip_prio_min;
+	int skip_prio_max;
+	int only_prio_min;
+	int only_prio_max;
+	unsigned long hits;
+};
+
+static LIST_HEAD(mglru_page_policies);
+static DEFINE_SPINLOCK(mglru_page_policy_lock);
+static unsigned int mglru_page_policy_count;
+
+static bool mglru_prio_matches(int priority, int prio_min, int prio_max)
+{
+	return priority >= prio_min && priority <= prio_max;
+}
+
+static struct mglru_page_policy *mglru_page_policy_find(unsigned long pfn)
+{
+	struct mglru_page_policy *policy;
+
+	lockdep_assert_held(&mglru_page_policy_lock);
+
+	list_for_each_entry(policy, &mglru_page_policies, list) {
+		if (policy->pfn == pfn)
+			return policy;
+	}
+
+	return NULL;
+}
+
+static struct folio *mglru_get_folio_by_pfn(unsigned long pfn)
+{
+	struct page *page = pfn_to_online_page(pfn);
+	struct folio *folio;
+
+	if (!page)
+		return NULL;
+
+	folio = page_folio(page);
+	if (!folio_try_get(folio))
+		return NULL;
+
+	if (unlikely(page_folio(page) != folio)) {
+		folio_put(folio);
+		return NULL;
+	}
+
+	return folio;
+}
+
+static int mglru_promote_folio_locked(struct lruvec *lruvec, struct folio *folio)
+{
+	int old_gen = folio_lru_gen(folio);
+	int new_gen = lru_gen_from_seq(lruvec->lrugen.max_seq);
+	unsigned long flags;
+
+	lockdep_assert_held(&lruvec->lru_lock);
+
+	if (old_gen < 0)
+		return -EINVAL;
+
+	if (old_gen == new_gen)
+		return new_gen;
+
+	flags = ((new_gen + 1UL) << LRU_GEN_PGOFF) | BIT(PG_workingset);
+	set_mask_bits(&folio->flags, LRU_GEN_MASK | LRU_REFS_FLAGS, flags);
+	lru_gen_update_size(lruvec, folio, old_gen, new_gen);
+
+	return new_gen;
+}
+
+static int mglru_promote_pfn(unsigned long pfn)
+{
+	int gen;
+	int err = 0;
+	struct folio *folio = mglru_get_folio_by_pfn(pfn);
+	struct lruvec *lruvec;
+	struct lru_gen_folio *lrugen;
+	int type, zone;
+
+	if (!folio)
+		return -ENOENT;
+
+	lruvec = folio_lruvec(folio);
+	spin_lock_irq(&lruvec->lru_lock);
+
+	if (!folio_test_lru(folio)) {
+		err = -EINVAL;
+		goto unlock;
+	}
+
+	gen = mglru_promote_folio_locked(lruvec, folio);
+	if (gen < 0) {
+		err = gen;
+		goto unlock;
+	}
+
+	lrugen = &lruvec->lrugen;
+	type = folio_is_file_lru(folio);
+	zone = folio_zonenum(folio);
+	list_move(&folio->lru, &lrugen->folios[gen][type][zone]);
+unlock:
+	spin_unlock_irq(&lruvec->lru_lock);
+	folio_put(folio);
+
+	return err;
+}
+
+static bool mglru_page_policy_reheat(struct folio *folio, struct scan_control *sc)
+{
+	bool reheat = false;
+	unsigned long flags;
+	unsigned long pfn = folio_pfn(folio);
+	struct mglru_page_policy *policy;
+
+	if (!READ_ONCE(mglru_page_policy_count))
+		return false;
+
+	spin_lock_irqsave(&mglru_page_policy_lock, flags);
+
+	policy = mglru_page_policy_find(pfn);
+	if (policy) {
+		if (policy->flags & MGLRU_PAGE_POLICY_PROTECT)
+			reheat = true;
+		if ((policy->flags & MGLRU_PAGE_POLICY_SKIP) &&
+		    mglru_prio_matches(sc->priority, policy->skip_prio_min,
+				       policy->skip_prio_max))
+			reheat = true;
+		if (reheat)
+			policy->hits++;
+	}
+
+	spin_unlock_irqrestore(&mglru_page_policy_lock, flags);
+
+	return reheat;
+}
+
+static bool mglru_page_policy_can_isolate(struct folio *folio, struct scan_control *sc)
+{
+	bool only_active = false;
+	bool only_match = false;
+	bool blocked = false;
+	unsigned long flags;
+	unsigned long pfn = folio_pfn(folio);
+	struct mglru_page_policy *policy;
+
+	if (!READ_ONCE(mglru_page_policy_count))
+		return true;
+
+	spin_lock_irqsave(&mglru_page_policy_lock, flags);
+
+	list_for_each_entry(policy, &mglru_page_policies, list) {
+		if ((policy->flags & MGLRU_PAGE_POLICY_ONLY) &&
+		    mglru_prio_matches(sc->priority, policy->only_prio_min,
+				       policy->only_prio_max)) {
+			only_active = true;
+			if (policy->pfn == pfn) {
+				only_match = true;
+				policy->hits++;
+			}
+		}
+
+		if (policy->pfn != pfn)
+			continue;
+
+		if (policy->flags & MGLRU_PAGE_POLICY_PROTECT) {
+			blocked = true;
+			policy->hits++;
+		}
+
+		if ((policy->flags & MGLRU_PAGE_POLICY_SKIP) &&
+		    mglru_prio_matches(sc->priority, policy->skip_prio_min,
+				       policy->skip_prio_max)) {
+			blocked = true;
+			policy->hits++;
+		}
+	}
+
+	spin_unlock_irqrestore(&mglru_page_policy_lock, flags);
+
+	if (blocked)
+		return false;
+
+	return !only_active || only_match;
+}
+
+static int mglru_page_policy_update(unsigned long pfn, unsigned int flag,
+				    bool add, int prio_min, int prio_max)
+{
+	unsigned long flags;
+	struct mglru_page_policy *policy;
+	struct mglru_page_policy *new = NULL;
+	struct mglru_page_policy *free = NULL;
+
+	if (add) {
+		new = kzalloc(sizeof(*new), GFP_KERNEL);
+		if (!new)
+			return -ENOMEM;
+		new->pfn = pfn;
+		new->skip_prio_min = 0;
+		new->skip_prio_max = DEF_PRIORITY;
+		new->only_prio_min = 0;
+		new->only_prio_max = DEF_PRIORITY;
+	}
+
+	spin_lock_irqsave(&mglru_page_policy_lock, flags);
+
+	policy = mglru_page_policy_find(pfn);
+	if (!policy && add) {
+		policy = new;
+		new = NULL;
+		list_add_tail(&policy->list, &mglru_page_policies);
+		WRITE_ONCE(mglru_page_policy_count, mglru_page_policy_count + 1);
+	}
+
+	if (!policy)
+		goto unlock;
+
+	if (add)
+		policy->flags |= flag;
+	else
+		policy->flags &= ~flag;
+
+	if (flag == MGLRU_PAGE_POLICY_SKIP) {
+		policy->skip_prio_min = prio_min;
+		policy->skip_prio_max = prio_max;
+	} else if (flag == MGLRU_PAGE_POLICY_ONLY) {
+		policy->only_prio_min = prio_min;
+		policy->only_prio_max = prio_max;
+	}
+
+	if (!policy->flags) {
+		list_del(&policy->list);
+		WRITE_ONCE(mglru_page_policy_count, mglru_page_policy_count - 1);
+		free = policy;
+	}
+unlock:
+	spin_unlock_irqrestore(&mglru_page_policy_lock, flags);
+
+	kfree(new);
+	kfree(free);
+
+	return 0;
+}
+
+static int mglru_apply_pfn_range(unsigned long pfn, unsigned long nr_pages,
+				 int (*fn)(unsigned long pfn, void *arg),
+				 void *arg)
+{
+	int err = 0;
+	int first_err = 0;
+	unsigned long end;
+	unsigned long done = 0;
+
+	if (!nr_pages || check_add_overflow(pfn, nr_pages, &end))
+		return -EINVAL;
+
+	while (pfn < end) {
+		struct folio *folio = mglru_get_folio_by_pfn(pfn);
+		unsigned long head;
+		unsigned long next = pfn + 1;
+
+		if (!folio) {
+			err = -ENOENT;
+			goto next;
+		}
+
+		if (!folio_test_lru(folio)) {
+			err = -EINVAL;
+			goto put_next;
+		}
+
+		head = folio_pfn(folio);
+		next = max(next, head + folio_nr_pages(folio));
+		err = fn(head, arg);
+		if (!err)
+			done++;
+put_next:
+		folio_put(folio);
+next:
+		if (err && !first_err)
+			first_err = err;
+		pfn = next;
+		cond_resched();
+	}
+
+	return done ? 0 : first_err;
+}
+
+struct mglru_page_policy_update_arg {
+	unsigned int flag;
+	bool add;
+	int prio_min;
+	int prio_max;
+};
+
+static int mglru_update_policy_pfn(unsigned long pfn, void *arg)
+{
+	struct mglru_page_policy_update_arg *update = arg;
+
+	return mglru_page_policy_update(pfn, update->flag, update->add,
+					update->prio_min, update->prio_max);
+}
+
+static int mglru_promote_policy_pfn(unsigned long pfn, void *arg)
+{
+	(void)arg;
+
+	return mglru_promote_pfn(pfn);
+}
+
+static void mglru_page_policy_clear_all(void)
+{
+	unsigned long flags;
+	struct mglru_page_policy *policy;
+	struct mglru_page_policy *next;
+	LIST_HEAD(free);
+
+	spin_lock_irqsave(&mglru_page_policy_lock, flags);
+	list_splice_init(&mglru_page_policies, &free);
+	WRITE_ONCE(mglru_page_policy_count, 0);
+	spin_unlock_irqrestore(&mglru_page_policy_lock, flags);
+
+	list_for_each_entry_safe(policy, next, &free, list) {
+		list_del(&policy->list);
+		kfree(policy);
+	}
+}
+
+static int mglru_parse_ulong(const char *str, unsigned long *value)
+{
+	return kstrtoul(str, 0, value);
+}
+
+static int mglru_parse_prio(const char *str, int *value)
+{
+	int err;
+
+	err = kstrtoint(str, 0, value);
+	if (err)
+		return err;
+
+	if (*value < 0 || *value > DEF_PRIORITY)
+		return -EINVAL;
+
+	return 0;
+}
+
+static int mglru_page_policy_parse_line(char *line)
+{
+	int argc = 0;
+	char *argv[8];
+	char *token;
+	unsigned long pfn, nr_pages;
+
+	while ((token = strsep(&line, " \t"))) {
+		if (!*token)
+			continue;
+		if (argc == ARRAY_SIZE(argv))
+			return -E2BIG;
+		argv[argc++] = token;
+	}
+
+	if (!argc)
+		return 0;
+
+	if (argc == 2 && !strcmp(argv[0], "clear") && !strcmp(argv[1], "all")) {
+		mglru_page_policy_clear_all();
+		return 0;
+	}
+
+	if (argc == 3 && !strcmp(argv[0], "promote")) {
+		if (mglru_parse_ulong(argv[1], &pfn) ||
+		    mglru_parse_ulong(argv[2], &nr_pages))
+			return -EINVAL;
+
+		return mglru_apply_pfn_range(pfn, nr_pages, mglru_promote_policy_pfn,
+					     NULL);
+	}
+
+	if (argc == 4 && !strcmp(argv[0], "protect")) {
+		struct mglru_page_policy_update_arg update = {
+			.flag = MGLRU_PAGE_POLICY_PROTECT,
+			.add = !strcmp(argv[1], "add"),
+			.prio_min = 0,
+			.prio_max = DEF_PRIORITY,
+		};
+
+		if (strcmp(argv[1], "add") && strcmp(argv[1], "del"))
+			return -EINVAL;
+		if (mglru_parse_ulong(argv[2], &pfn) ||
+		    mglru_parse_ulong(argv[3], &nr_pages))
+			return -EINVAL;
+
+		return mglru_apply_pfn_range(pfn, nr_pages, mglru_update_policy_pfn,
+					     &update);
+	}
+
+	if (argc == 7 && !strcmp(argv[0], "scan")) {
+		struct mglru_page_policy_update_arg update = {
+			.add = !strcmp(argv[2], "add"),
+		};
+
+		if (!strcmp(argv[1], "skip"))
+			update.flag = MGLRU_PAGE_POLICY_SKIP;
+		else if (!strcmp(argv[1], "only"))
+			update.flag = MGLRU_PAGE_POLICY_ONLY;
+		else
+			return -EINVAL;
+
+		if (strcmp(argv[2], "add") && strcmp(argv[2], "del"))
+			return -EINVAL;
+		if (mglru_parse_prio(argv[3], &update.prio_min) ||
+		    mglru_parse_prio(argv[4], &update.prio_max) ||
+		    update.prio_min > update.prio_max ||
+		    mglru_parse_ulong(argv[5], &pfn) ||
+		    mglru_parse_ulong(argv[6], &nr_pages))
+			return -EINVAL;
+
+		return mglru_apply_pfn_range(pfn, nr_pages, mglru_update_policy_pfn,
+					     &update);
+	}
+
+	return -EINVAL;
+}
+
+static ssize_t mglru_page_policy_write(struct file *file, const char __user *src,
+				       size_t len, loff_t *pos)
+{
+	void *buf;
+	char *cur, *next;
+	int err = 0;
+
+	if (!len)
+		return 0;
+	if (len > SZ_64K)
+		return -E2BIG;
+
+	buf = kvmalloc(len + 1, GFP_KERNEL);
+	if (!buf)
+		return -ENOMEM;
+
+	if (copy_from_user(buf, src, len)) {
+		err = -EFAULT;
+		goto done;
+	}
+
+	next = buf;
+	next[len] = '\0';
+
+	while ((cur = strsep(&next, ",;\n"))) {
+		cur = strim(cur);
+		if (!*cur)
+			continue;
+
+		err = mglru_page_policy_parse_line(cur);
+		if (err)
+			break;
+	}
+done:
+	kvfree(buf);
+
+	return err ?: len;
+}
+
+static int mglru_page_policy_show(struct seq_file *m, void *v)
+{
+	unsigned long flags;
+	struct mglru_page_policy *policy;
+
+	seq_puts(m, "# commands:\n");
+	seq_puts(m, "#   promote <pfn> <nr_pages>\n");
+	seq_puts(m, "#   protect add|del <pfn> <nr_pages>\n");
+	seq_puts(m, "#   scan skip add|del <prio_min> <prio_max> <pfn> <nr_pages>\n");
+	seq_puts(m, "#   scan only add|del <prio_min> <prio_max> <pfn> <nr_pages>\n");
+	seq_puts(m, "#   clear all\n");
+	seq_puts(m, "# pfn flags skip_prio_min skip_prio_max only_prio_min only_prio_max hits\n");
+
+	spin_lock_irqsave(&mglru_page_policy_lock, flags);
+	list_for_each_entry(policy, &mglru_page_policies, list) {
+		seq_printf(m, "%lu %c%c%c %d %d %d %d %lu\n",
+			   policy->pfn,
+			   policy->flags & MGLRU_PAGE_POLICY_PROTECT ? 'P' : '-',
+			   policy->flags & MGLRU_PAGE_POLICY_SKIP ? 'S' : '-',
+			   policy->flags & MGLRU_PAGE_POLICY_ONLY ? 'O' : '-',
+			   policy->skip_prio_min, policy->skip_prio_max,
+			   policy->only_prio_min, policy->only_prio_max,
+			   policy->hits);
+	}
+	spin_unlock_irqrestore(&mglru_page_policy_lock, flags);
+
+	return 0;
+}
+
+static int mglru_page_policy_open(struct inode *inode, struct file *file)
+{
+	return single_open(file, mglru_page_policy_show, NULL);
+}
+
+static const struct file_operations mglru_page_policy_fops = {
+	.open = mglru_page_policy_open,
+	.read = seq_read,
+	.write = mglru_page_policy_write,
+	.llseek = seq_lseek,
+	.release = single_release,
+};
